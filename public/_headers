/sw.js
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0, s-maxage=0
  CDN-Cache-Control: no-store
  Cloudflare-CDN-Cache-Control: no-store
  Surrogate-Control: no-store
  Pragma: no-cache
  Expires: 0
  Vary: *
  Service-Worker-Allowed: /
  Content-Type: text/javascript; charset=utf-8

/service-worker.js
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0, s-maxage=0
  CDN-Cache-Control: no-store
  Cloudflare-CDN-Cache-Control: no-store
  Surrogate-Control: no-store
  Pragma: no-cache
  Expires: 0
  Vary: *
  Service-Worker-Allowed: /
  Content-Type: text/javascript; charset=utf-8
/site.webmanifest
  Content-Type: application/manifest+json; charset=utf-8
  Cache-Control: public, max-age=3600

# User-editable downloads must revalidate at the browser and never stick at
# the CDN edge, so re-uploaded PDFs become visible without a manual purge.
/downloads/*
  Cache-Control: public, max-age=300, must-revalidate
  CDN-Cache-Control: no-store
  Cloudflare-CDN-Cache-Control: no-store
  Surrogate-Control: no-store

# Hashed Vite build output — filename-based cache-busting means these are
# safe to cache forever. Critical: HTML shells must NOT be cached (handled
# in src/server.ts) so a new build's HTML always points at fresh hashed
# asset URLs, avoiding the stale-shell → hydration mismatch class of bugs.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/_build/*
  Cache-Control: public, max-age=31536000, immutable

# Payment/webhook/cron endpoints must never be cached anywhere — stale
# order/payment status would be impossible to recover from.
/api/payments/*
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0, s-maxage=0
  CDN-Cache-Control: no-store
  Cloudflare-CDN-Cache-Control: no-store
  Surrogate-Control: no-store
  Pragma: no-cache
  Expires: 0
  Vary: *

/api/webhooks/*
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0, s-maxage=0
  CDN-Cache-Control: no-store
  Cloudflare-CDN-Cache-Control: no-store
  Surrogate-Control: no-store
  Pragma: no-cache
  Expires: 0
  Vary: *

