rules_version = '2';

// PH Labs — Firestore security rules
// Source of truth — deploy with: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/customers/$(request.auth.uid))
        && get(/databases/$(database)/documents/customers/$(request.auth.uid)).data.isAdmin == true;
    }
    // Prevent users from elevating their own privileges.
    function notTouchingPrivilegedFields() {
      return !('isAdmin' in request.resource.data.diff(resource.data).affectedKeys())
          && !('role'    in request.resource.data.diff(resource.data).affectedKeys())
          && !('isVip'   in request.resource.data.diff(resource.data).affectedKeys());
    }

    // ---------- customers ----------
    // Users can read & update their OWN profile (without changing isAdmin/role/isVip).
    // Admins can read & write any.
    match /customers/{uid} {
      allow read:   if isSelf(uid) || isAdmin();
      allow create: if isSelf(uid)
                    && !('isAdmin' in request.resource.data)
                    && !('role'    in request.resource.data)
                    && !('isVip'   in request.resource.data);
      allow update: if (isSelf(uid) && notTouchingPrivilegedFields()) || isAdmin();
      allow delete: if isAdmin();
    }

    // ---------- orders ----------
    // SECURITY: Client-side order creation is DISABLED. Orders are written
    // exclusively by the `createOrder` server function (TanStack server fn)
    // which re-validates cart prices/stock/coupon against `product_stock`
    // and computes the authoritative subtotal/discount/shipping/total
    // before writing via the Firebase service account (bypasses these
    // rules). This prevents price-tampering attacks where a client could
    // POST an order with totalAmount=0.01 directly via the Firebase SDK.
    //
    // Owners can read their own; only admins can mutate after creation,
    // except a signed-in owner may attach a short customer note.
    function isOrderOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }
    function ownerNoteOnlyUpdate() {
      // Owner may only touch `customerNote` (and a timestamp) — nothing else.
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['customerNote', 'customerNoteUpdatedAt'])
          && (!('customerNote' in request.resource.data)
              || (request.resource.data.customerNote is string
                  && request.resource.data.customerNote.size() <= 1000));
    }
    match /orders/{orderId} {
      allow create: if false; // server-only — see createOrder server fn
      allow read:   if isAdmin() || isOrderOwner();
      allow update: if isAdmin() || (isOrderOwner() && ownerNoteOnlyUpdate());
      allow delete: if isAdmin();
    }


    // ---------- email subscribers (newsletter) ----------
    match /emailSubscribers/{docId} {
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.size() < 320;
      allow read, update, delete: if isAdmin();
    }

    // GDPR Data Subject Requests (DSR) — anyone can create with a locked
    // shape; only admins can read / update / delete. Identity verification
    // happens out-of-band via email reply before the request is fulfilled.
    match /dsrRequests/{docId} {
      allow create: if request.resource.data.keys().hasAll(['type','email','fullName','status','createdAt','source'])
                    && request.resource.data.type in ['access','rectification','deletion','portability','objection','restriction']
                    && request.resource.data.email is string
                    && request.resource.data.email.size() < 320
                    && request.resource.data.fullName is string
                    && request.resource.data.fullName.size() < 200
                    && request.resource.data.status == 'pending'
                    && request.resource.data.source is string
                    && (!('details' in request.resource.data) || (request.resource.data.details is string && request.resource.data.details.size() < 4000));
      allow read, update, delete: if isAdmin();
    }

    // ---------- public-read, admin-write collections ----------
    match /products/{id}        { allow read: if true; allow write: if isAdmin(); }
    match /product_stock/{id}   { allow read: if true; allow write: if isAdmin(); }
    match /inventory/{id}       { allow read: if true; allow write: if isAdmin(); }
    match /adverts/{id}         { allow read: if true; allow write: if isAdmin(); }
    match /settings/{id}        { allow read: if true; allow write: if isAdmin(); }
    match /siteSettings/{id}    { allow read: if true; allow write: if isAdmin(); }
    match /site_config/{id}     { allow read: if true; allow write: if isAdmin(); }
    match /banners/{id}         { allow read: if true; allow write: if isAdmin(); }
    match /landingPage/{id}     { allow read: if true; allow write: if isAdmin(); }
    match /themes/{id}          { allow read: if true; allow write: if isAdmin(); }
    match /policies/{id}        { allow read: if true; allow write: if isAdmin(); }
    match /articles/{id}        { allow read: if true; allow write: if isAdmin(); }
    match /featuredProducts/{id}{ allow read: if true; allow write: if isAdmin(); }

    // ---------- admin-only collections ----------
    match /coupons/{id}         { allow read: if isAdmin(); allow write: if isAdmin(); }
    match /promoCodes/{id}      { allow read: if isAdmin(); allow write: if isAdmin(); }
    match /ipWhitelist/{id}     { allow read: if isAdmin(); allow write: if isAdmin(); }
    match /mail/{id} {
      // Trigger Email extension target.
      // Guest emails (contact form, newsletter, guest checkout) are written
      // by the /api/public/send-mail server route using a service-account
      // credential (which bypasses rules). Client writes are restricted to
      // admins so an attacker cannot use this collection as an open relay.
      allow create: if isAdmin()
                    && request.resource.data.to is string
                    && request.resource.data.to.size() > 3
                    && request.resource.data.to.size() < 320
                    && request.resource.data.to.matches('.+@.+\\..+')
                    && request.resource.data.message is map
                    && request.resource.data.message.subject is string
                    && request.resource.data.message.subject.size() < 200
                    && request.resource.data.message.html is string
                    && request.resource.data.message.html.size() < 200000;
      allow read, update, delete: if isAdmin();
    }
    match /invoices/{id}        { allow read: if isAdmin(); allow write: if isAdmin(); }
    match /backups/{id}         { allow read: if isAdmin(); allow write: if isAdmin(); }
    match /emailMarketing/{id}  { allow read: if isAdmin(); allow write: if isAdmin(); }

    // ---------- audit logs (append-only) ----------
    // Any signed-in admin may APPEND a log entry from the admin panel so
    // privileged actions are auditable. Nobody — not even admins from the
    // client — may update or delete past entries. Server-side service
    // accounts (firebase-admin) bypass rules entirely for back-fills.
    match /auditLogs/{id} {
      allow read:   if isAdmin();
      allow create: if isAdmin()
                    && request.resource.data.adminUid == request.auth.uid
                    && request.resource.data.action is string
                    && request.resource.data.action.size() > 0
                    && request.resource.data.action.size() < 64
                    && request.resource.data.target is string
                    && request.resource.data.target.size() < 256;
      allow update, delete: if false;
    }

    // ---------- URL monitor scans (append-only by server) ----------
    // Written by /api/public/hooks/monitor-product-urls via firebase-admin
    // (bypasses rules). Admins read the history in the URL Monitor tab.
    // Clients never write.
    match /url_monitor_scans/{id} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // ---------- auth events (append-only diagnostic log) ----------
    // Anyone (including unauthenticated visitors) may CREATE an auth event so
    // failed logins are still captured. The shape is locked down to prevent
    // abuse as a free-form data dump. Only admins read; nobody edits or deletes.
    match /auth_events/{id} {
      allow read: if isAdmin();
      allow create: if request.resource.data.type is string
                    && request.resource.data.type.size() > 0
                    && request.resource.data.type.size() < 64
                    && request.resource.data.createdAt == request.time
                    && (!('email' in request.resource.data)
                        || request.resource.data.email == null
                        || (request.resource.data.email is string
                            && request.resource.data.email.size() < 320))
                    && (!('uid' in request.resource.data)
                        || request.resource.data.uid == null
                        || (request.resource.data.uid is string
                            && request.resource.data.uid.size() < 64))
                    && (!('code' in request.resource.data)
                        || request.resource.data.code == null
                        || (request.resource.data.code is string
                            && request.resource.data.code.size() < 100))
                    && (!('message' in request.resource.data)
                        || request.resource.data.message == null
                        || (request.resource.data.message is string
                            && request.resource.data.message.size() < 300))
                    && (!('source' in request.resource.data)
                        || request.resource.data.source == null
                        || (request.resource.data.source is string
                            && request.resource.data.source.size() < 200))
                    && (!('userAgent' in request.resource.data)
                        || request.resource.data.userAgent == null
                        || (request.resource.data.userAgent is string
                            && request.resource.data.userAgent.size() < 300));
      allow update, delete: if false;
    }

    // ---------- cart events (append-only cart/checkout telemetry) ----------
    // Anyone (including unauthenticated shoppers) may CREATE a cart event so
    // localStorage failures + state drift are still captured. Shape is locked.
    // Admin-only read. No updates / deletes.
    match /cart_events/{id} {
      allow read: if isAdmin();
      allow create: if request.resource.data.type is string
                    && request.resource.data.type.size() > 0
                    && request.resource.data.type.size() < 64
                    && request.resource.data.createdAt == request.time
                    && (!('memoryCount' in request.resource.data)
                        || request.resource.data.memoryCount == null
                        || request.resource.data.memoryCount is int)
                    && (!('storedCount' in request.resource.data)
                        || request.resource.data.storedCount == null
                        || request.resource.data.storedCount is int)
                    && (!('source' in request.resource.data)
                        || request.resource.data.source == null
                        || (request.resource.data.source is string
                            && request.resource.data.source.size() < 200))
                    && (!('code' in request.resource.data)
                        || request.resource.data.code == null
                        || (request.resource.data.code is string
                            && request.resource.data.code.size() < 100))
                    && (!('message' in request.resource.data)
                        || request.resource.data.message == null
                        || (request.resource.data.message is string
                            && request.resource.data.message.size() < 300))
                    && (!('key' in request.resource.data)
                        || request.resource.data.key == null
                        || (request.resource.data.key is string
                            && request.resource.data.key.size() < 100))
                    && (!('userAgent' in request.resource.data)
                        || request.resource.data.userAgent == null
                        || (request.resource.data.userAgent is string
                            && request.resource.data.userAgent.size() < 300))
                    && (!('extra' in request.resource.data)
                        || request.resource.data.extra == null
                        || (request.resource.data.extra is string
                            && request.resource.data.extra.size() < 500));
      allow update, delete: if false;
    }

    // ---------- loginAttempts (brute-force lockout tracker) ----------
    // Written by the client BEFORE auth completes — must allow unauthenticated
    // create/update with a tightly locked schema. Doc id is a hashed email
    // (see src/lib/login-lockout.ts). Read is admin-only.
    match /loginAttempts/{id} {
      allow read:   if isAdmin();
      allow create, update: if request.resource.data.failures is int
                            && request.resource.data.failures >= 0
                            && request.resource.data.failures < 1000
                            && request.resource.data.emailHash is string
                            && request.resource.data.emailHash.size() < 220
                            && (!('lockedUntil' in request.resource.data)
                                || request.resource.data.lockedUntil == null
                                || request.resource.data.lockedUntil is timestamp)
                            && (!('ip' in request.resource.data)
                                || request.resource.data.ip == null
                                || (request.resource.data.ip is string
                                    && request.resource.data.ip.size() < 64));
      allow delete: if isAdmin();
    }

    // ---------- securityEvents (append-only diagnostic log) ----------
    // Generic security event log — ErrorBoundary, lockout, idle logout,
    // admin login failures, password changes. Append-only; admin-read.
    // Allowed from both authenticated AND unauthenticated contexts (so a
    // failed /admin login from an unauth session still records).
    match /securityEvents/{id} {
      allow read:   if isAdmin();
      allow create: if request.resource.data.type is string
                    && request.resource.data.type.size() > 0
                    && request.resource.data.type.size() < 64
                    && request.resource.data.createdAt == request.time
                    && (!('uid' in request.resource.data)
                        || request.resource.data.uid == null
                        || (request.resource.data.uid is string
                            && request.resource.data.uid.size() < 64
                            && (request.auth == null || request.resource.data.uid == request.auth.uid)))
                    && (!('route' in request.resource.data)
                        || request.resource.data.route == null
                        || (request.resource.data.route is string
                            && request.resource.data.route.size() < 300))
                    && (!('message' in request.resource.data)
                        || request.resource.data.message == null
                        || (request.resource.data.message is string
                            && request.resource.data.message.size() < 600))
                    && (!('userAgent' in request.resource.data)
                        || request.resource.data.userAgent == null
                        || (request.resource.data.userAgent is string
                            && request.resource.data.userAgent.size() < 300));
      allow update, delete: if false;
    }



    // ---------- fena webhook events (admin-read diagnostic log) ----------
    // Written exclusively by the /api/public/hooks/fena server route via
    // firebase-admin (bypasses rules). Admins read from the Fena tab.
    match /fena_webhook_events/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ---------- fena orphan payments (admin-read reconciliation queue) ----------
    // Webhook writes here when a Fena payment arrives with no matching order.
    // Admin reads from the Fena tab to manually reconcile (refund / re-link).
    match /fena_orphan_payments/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }
    // ---------- fena bank accounts (mirrored from Fena via webhook) ----------
    // Webhook writes here on bank-accounts/* events after re-fetch.
    // Admin reads from the Fena tab.
    match /fena_bank_accounts/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ---------- payment_gateways (admin-managed config, server-written) ----------
    // Stores toggle / priority / sandbox / health for Fena, TrueLayer, Yapily.
    // NEVER stores API keys (those live in server-side secrets). Read is
    // public so the checkout page can render the active gateway label without
    // a server round-trip; write is admin-only via server functions.
    match /payment_gateways/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- payment webhook events (admin-read diagnostic log) ----------
    match /payment_webhook_events/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /payment_orphans/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ---------- lab reports (user-imported PDFs via PWA file_handlers) ----------
    // Each doc is owned by a single user. Owner can CRUD their own; admins can read all.
    // Schema is locked so the collection can't be repurposed.
    match /lab_reports/{id} {
      allow read:   if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() < 256
                    && request.resource.data.size is int
                    && request.resource.data.size > 0
                    && request.resource.data.size < 10 * 1024 * 1024
                    && request.resource.data.storagePath is string
                    && request.resource.data.storagePath.size() < 512
                    && request.resource.data.url is string
                    && request.resource.data.url.size() < 2048
                    && request.resource.data.createdAt == request.time;
      allow update: if false;
      allow delete: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
    }


    // ---------- default deny ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
