rules_version = '2';

// PH Labs — Firestore security rules
// Source of truth — deploy with: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/customers/$(request.auth.uid))
        && get(/databases/$(database)/documents/customers/$(request.auth.uid)).data.isAdmin == true;
    }
    // Prevent users from elevating their own privileges.
    function notTouchingPrivilegedFields() {
      return !('isAdmin' in request.resource.data.diff(resource.data).affectedKeys())
          && !('role'    in request.resource.data.diff(resource.data).affectedKeys())
          && !('isVip'   in request.resource.data.diff(resource.data).affectedKeys());
    }

    // ---------- customers ----------
    // Users can read & update their OWN profile (without changing isAdmin/role/isVip).
    // Admins can read & write any.
    match /customers/{uid} {
      allow read:   if isSelf(uid) || isAdmin();
      allow create: if isSelf(uid)
                    && !('isAdmin' in request.resource.data)
                    && !('role'    in request.resource.data)
                    && !('isVip'   in request.resource.data);
      allow update: if (isSelf(uid) && notTouchingPrivilegedFields()) || isAdmin();
      allow delete: if isAdmin();
    }

    // ---------- orders ----------
    // Anyone (incl. guests) can CREATE an order at checkout, but the payload
    // must look like a real checkout submission — block attempts to seed
    // arbitrary admin-controlled fields (paid status, refunds, fulfilment).
    // Owners can read their own; only admins can mutate after creation,
    // except a signed-in owner may attach a short customer note.
    function isOrderOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }
    function validOrderCreate() {
      let d = request.resource.data;
      return d.totalAmount is number && d.totalAmount >= 0
          && d.subtotal is number && d.subtotal >= 0
          && d.orderId is string && d.orderId.size() > 0 && d.orderId.size() < 64
          && d.items is list && d.items.size() > 0 && d.items.size() <= 50
          && d.customer is map
          && d.customer.email is string && d.customer.email.size() < 320
          && d.status == 'pending_payment'
          && d.paymentMethod is string
          // UK research-peptide compliance: 18+ confirmation must be present.
          && d.ageVerified == true
          && (!('userId' in d) || d.userId == null || (isSignedIn() && d.userId == request.auth.uid))
          // Never trust client-set admin/fulfilment fields at creation time.
          && !('paid' in d) && !('paidAt' in d)
          && !('refunded' in d) && !('refundedAt' in d) && !('refundAmount' in d)
          && !('dispatched' in d) && !('dispatchedAt' in d)
          && !('trackingNumber' in d) && !('trackingUrl' in d)
          && !('adminNotes' in d) && !('internalNotes' in d);
    }
    function ownerNoteOnlyUpdate() {
      // Owner may only touch `customerNote` (and a timestamp) — nothing else.
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['customerNote', 'customerNoteUpdatedAt'])
          && (!('customerNote' in request.resource.data)
              || (request.resource.data.customerNote is string
                  && request.resource.data.customerNote.size() <= 1000));
    }
    match /orders/{orderId} {
      allow create: if validOrderCreate();
      allow read:   if isAdmin() || isOrderOwner();
      allow update: if isAdmin() || (isOrderOwner() && ownerNoteOnlyUpdate());
      allow delete: if isAdmin();
    }


    // ---------- email subscribers (newsletter) ----------
    match /emailSubscribers/{docId} {
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.size() < 320;
      allow read, update, delete: if isAdmin();
    }

    // ---------- public-read, admin-write collections ----------
    match /products/{id}        { allow read: if true; allow write: if isAdmin(); }
    match /product_stock/{id}   { allow read: if true; allow write: if isAdmin(); }
    match /inventory/{id}       { allow read: if true; allow write: if isAdmin(); }
    match /adverts/{id}         { allow read: if true; allow write: if isAdmin(); }
    match /settings/{id}        { allow read: if true; allow write: if isAdmin(); }
    match /banners/{id}         { allow read: if true; allow write: if isAdmin(); }
    match /landingPage/{id}     { allow read: if true; allow write: if isAdmin(); }
    match /themes/{id}          { allow read: if true; allow write: if isAdmin(); }
    match /policies/{id}        { allow read: if true; allow write: if isAdmin(); }
    match /articles/{id}        { allow read: if true; allow write: if isAdmin(); }
    match /featuredProducts/{id}{ allow read: if true; allow write: if isAdmin(); }

    // ---------- admin-only collections ----------
    match /coupons/{id}         { allow read: if isAdmin(); allow write: if isAdmin(); }
    match /promoCodes/{id}      { allow read: if isAdmin(); allow write: if isAdmin(); }
    match /ipWhitelist/{id}     { allow read: if isAdmin(); allow write: if isAdmin(); }
    match /mail/{id} {
      // Trigger Email extension target.
      // Guest emails (contact form, newsletter, guest checkout) are written
      // by the /api/public/send-mail server route using a service-account
      // credential (which bypasses rules). Client writes are restricted to
      // admins so an attacker cannot use this collection as an open relay.
      allow create: if isAdmin()
                    && request.resource.data.to is string
                    && request.resource.data.to.size() > 3
                    && request.resource.data.to.size() < 320
                    && request.resource.data.to.matches('.+@.+\\..+')
                    && request.resource.data.message is map
                    && request.resource.data.message.subject is string
                    && request.resource.data.message.subject.size() < 200
                    && request.resource.data.message.html is string
                    && request.resource.data.message.html.size() < 200000;
      allow read, update, delete: if isAdmin();
    }
    match /invoices/{id}        { allow read: if isAdmin(); allow write: if isAdmin(); }
    match /backups/{id}         { allow read: if isAdmin(); allow write: if isAdmin(); }
    match /emailMarketing/{id}  { allow read: if isAdmin(); allow write: if isAdmin(); }

    // ---------- audit logs (append-only) ----------
    // Any signed-in admin may APPEND a log entry from the admin panel so
    // privileged actions are auditable. Nobody — not even admins from the
    // client — may update or delete past entries. Server-side service
    // accounts (firebase-admin) bypass rules entirely for back-fills.
    match /auditLogs/{id} {
      allow read:   if isAdmin();
      allow create: if isAdmin()
                    && request.resource.data.adminUid == request.auth.uid
                    && request.resource.data.action is string
                    && request.resource.data.action.size() > 0
                    && request.resource.data.action.size() < 64
                    && request.resource.data.target is string
                    && request.resource.data.target.size() < 256;
      allow update, delete: if false;
    }

    // ---------- default deny ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
