      {
        "@type": "ListItem",
        "item": "https://phlabs.co.uk/resources/mots-c-mitochondrial-derived-peptide",
        "name": "MOTS-C: The Mitochondrial-Derived Peptide Regulating Metabolic Homeostasis and Exercise Adaptation",
