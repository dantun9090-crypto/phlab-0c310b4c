    "image": [
      "https://phlabs.co.uk/og-image.jpg",
    ],
    "inLanguage": "en-GB",
    "isAccessibleForFree": true,
    "keywords": "peptide storage, lyophilisation, freeze-drying, reconstitution, peptide stability, research chemicals, storage conditions",
